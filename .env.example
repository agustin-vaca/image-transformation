# Cloudflare R2 (S3-compatible API)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=images
# e.g. https://pub-<hash>.r2.dev or your custom domain
R2_PUBLIC_BASE_URL=

# Public URL of the deployed app (used to build shareUrl)
# e.g. https://image-transformation-xyz.vercel.app
APP_BASE_URL=http://localhost:3000

# Random secret used to authorize the cleanup cron endpoint
# Generate with: [Convert]::ToBase64String((1..32 | %{ Get-Random -Maximum 256 }))
CRON_SECRET=
